# Cloudflare API token with DNS Edit permissions
CF_API_TOKEN=your_cloudflare_api_token

# Root domain name managed in Cloudflare (e.g. example.com) — NOT the zone ID hash
CF_ZONE_ID=example.com

# Full DNS record name to keep updated
CF_RECORD_NAME=home.example.com

# Email address associated with your Cloudflare account
CF_EMAIL=your_email@example.com

# How often to check for an IP change (seconds)
CHECK_INTERVAL=300

# Timezone for log timestamps (optional, defaults to UTC)
TZ=UTC
